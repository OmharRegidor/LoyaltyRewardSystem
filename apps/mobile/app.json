{
  "expo": {
    "name": "NoxaLoyalty",
    "slug": "loyaltyhub",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/images/logoloyalty.png",
    "scheme": "noxaloyalty",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logoloyalty.png",
      "resizeMode": "contain",
      "backgroundColor": "#edeef0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.NoxaLoyalty.app",
      "newArchEnabled": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "versionCode": 4,
      "package": "com.NoxaLoyalty.app",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#edeef0",
        "foregroundImage": "./assets/images/adaptive-icon(1).png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "noxaloyalty",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      ["@react-native-google-signin/google-signin", {
        "iosUrlScheme": "com.googleusercontent.apps.151913803842-6lb7rn7t9figsh9umvi54j6g0cvdngrc"
      }],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "android": {
            "defaultChannel": "default",
            "channelId": "default",
            "channelName": "Default"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "be2191a5-1512-4284-a3a5-25820121673a"
      }
    }
  }
}
